# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าของคุณเอง — ห้าม commit ไฟล์ .env เด็ดขาด
JIRA_BASE_URL=https://your-company.atlassian.net
# อีเมลบัญชี Atlassian ของคุณ (ที่ใช้ login Jira)
JIRA_EMAIL=your.name@your-company.com
# สร้าง API token ของตัวเองที่ https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here
